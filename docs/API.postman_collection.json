{
  "info": {
    "name": "Inventory API - AWS Project",
    "description": "Complete API test collection for both Lambda and ECS architectures",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "api_url",
      "value": "https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/prod",
      "type": "string"
    },
    {
      "key": "item_id",
      "value": "{{$guid}}",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{api_url}}/health",
          "host": ["{{api_url}}"],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "List All Items",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{api_url}}/items",
          "host": ["{{api_url}}"],
          "path": ["items"]
        }
      },
      "response": []
    },
    {
      "name": "Create Item",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.variables.set(\"item_id\", pm.variables.replaceIn('{{$guid}}'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"{{item_id}}\",\n  \"name\": \"Laptop\",\n  \"quantity\": 5,\n  \"description\": \"Dell XPS 15\",\n  \"category\": \"Electronics\",\n  \"unit_value\": 1299.99\n}"
        },
        "url": {
          "raw": "{{api_url}}/items",
          "host": ["{{api_url}}"],
          "path": ["items"]
        }
      },
      "response": []
    },
    {
      "name": "Get Item by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{api_url}}/items/{{item_id}}",
          "host": ["{{api_url}}"],
          "path": ["items", "{{item_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Update Item",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Laptop Pro\",\n  \"quantity\": 10,\n  \"description\": \"Dell XPS 15 - Updated\",\n  \"category\": \"Electronics\",\n  \"unit_value\": 1499.99\n}"
        },
        "url": {
          "raw": "{{api_url}}/items/{{item_id}}",
          "host": ["{{api_url}}"],
          "path": ["items", "{{item_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Delete Item",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{api_url}}/items/{{item_id}}",
          "host": ["{{api_url}}"],
          "path": ["items", "{{item_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Get Deleted Item (Should 404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{api_url}}/items/{{item_id}}",
          "host": ["{{api_url}}"],
          "path": ["items", "{{item_id}}"]
        }
      },
      "response": []
    }
  ]
}
